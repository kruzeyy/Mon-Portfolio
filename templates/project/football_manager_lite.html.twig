{% extends 'base.html.twig' %}

{% block title %}Football Manager Lite — {{ site_name }}{% endblock %}

{% block body %}
    <div class="project-page">
        <a class="skip-link" href="#contenu-principal">Aller au contenu</a>

        <header class="site-header" id="top">
            <div class="container header-inner">
                <div class="brand">
                    <a href="{{ path('app_home') }}#accueil" class="brand-link">{{ site_name }}</a>
                    <p class="brand-tagline">
                        Sites vitrines &amp; présence web · {{ business_statut }} · {{ business_region }}
                    </p>
                </div>
                <button
                    type="button"
                    class="nav-toggle"
                    aria-expanded="false"
                    aria-controls="site-nav"
                    aria-label="Ouvrir le menu"
                >
                    <span class="nav-toggle-bar"></span>
                    <span class="nav-toggle-bar"></span>
                </button>
                <nav class="site-nav" id="site-nav" aria-label="Navigation principale">
                    <ul class="nav-list">
                        <li><a href="{{ path('app_home') }}#accueil">Accueil</a></li>
                        <li><a href="{{ path('app_home') }}#pourquoi-site">Pourquoi un site</a></li>
                        <li><a href="{{ path('app_home') }}#prestations">Services</a></li>
                        <li><a href="{{ path('app_home') }}#demarche">Démarche</a></li>
                        <li><a href="{{ path('app_home') }}#projets">Réalisations</a></li>
                        <li><a href="{{ path('app_home') }}#a-propos">À propos</a></li>
                        <li><a href="{{ path('app_home') }}#faq">FAQ</a></li>
                        <li><a href="{{ path('app_home') }}#contact">Contact</a></li>
                    </ul>
                </nav>
            </div>
        </header>

        <main id="contenu-principal" class="container section" style="padding-top: 2rem;">
            <p class="project-breadcrumb">
                <a href="{{ path('app_home') }}">Accueil</a>
                · <a href="{{ path('app_home') }}#projets">Projets</a>
                · Football Manager Lite
            </p>

            <header class="project-detail-hero">
                <div class="project-detail-hero-banner">
                    <img
                        src="https://placehold.co/1200x480/14532d/bef264?text=Football+Manager+Lite"
                        alt="Visuel du projet Football Manager Lite"
                        width="1200"
                        height="480"
                        loading="eager"
                    />
                </div>
                <p class="project-detail-tag project-detail-tag--personal">Projet personnel</p>
                <h1>Football Manager Lite</h1>
                <p class="project-detail-lead">
                    Mini <strong>jeu de management football</strong> dans l’esprit Football Manager : ligue générée,
                    calendrier, simulation de matchs et navigation par onglets — le tout dans le navigateur,
                    avec persistance locale.
                </p>

                <p class="project-detail-actions">
                    <a
                        href="https://github.com/kruzeyy/football-manager-lite"
                        class="btn btn-primary"
                        target="_blank"
                        rel="noopener noreferrer"
                    >Code sur GitHub</a>
                    <a href="{{ path('app_home') }}#projets" class="btn btn-ghost">← Retour aux projets</a>
                </p>
            </header>

            <section class="project-detail-section" aria-labelledby="stack-fm-title">
                <h2 id="stack-fm-title">Stack</h2>
                <ul class="tech-chips">
                    <li>React</li>
                    <li>TypeScript</li>
                    <li>Vite</li>
                </ul>
            </section>

            <section class="project-detail-section" aria-labelledby="feat-fm-title">
                <h2 id="feat-fm-title">Fonctionnalités</h2>
                <ul>
                    <li>Génération d’une <strong>ligue de 12 équipes</strong> avec effectifs.</li>
                    <li><strong>Calendrier aller-retour</strong> (round-robin).</li>
                    <li><strong>Moteur de match</strong> simplifié (buts, points).</li>
                    <li>Vues : <strong>tableau de bord</strong>, <strong>effectif</strong>, <strong>calendrier</strong>, <strong>jour de match</strong>.</li>
                    <li><strong>Sauvegarde / chargement</strong> automatique via <code>localStorage</code>.</li>
                </ul>
            </section>

            <section class="project-detail-section" aria-labelledby="run-fm-title">
                <h2 id="run-fm-title">Lancer le projet</h2>
                <p>Prérequis : <strong>Node.js 18+</strong>.</p>
                <div class="detail-code"><pre>npm install
npm run dev</pre></div>
                <p>Ouvrir l’URL affichée (souvent <code>http://localhost:5173</code>).</p>
                <p>
                    Build production : <code>npm run build</code> puis <code>npm run preview</code>.
                </p>
            </section>

            <section class="project-detail-section" aria-labelledby="struct-fm-title">
                <h2 id="struct-fm-title">Structure</h2>
                <ul>
                    <li><code>src/game</code> — modèles, génération, calendrier, moteur, persistance</li>
                    <li><code>src/components</code> — interfaces</li>
                    <li><code>src/App.tsx</code> — navigation par onglets</li>
                </ul>
            </section>

            <div class="project-detail-notes" role="note">
                <strong>Notes</strong>
                <ul>
                    <li>Le moteur est volontairement simple et perfectible (xG approximatif, sampling).</li>
                    <li>Difficulté ajustable via les forces d’équipe et l’avantage domicile (voir code).</li>
                </ul>
                <p style="margin: 0.75rem 0 0;">
                    Le dépôt contient aussi des guides complémentaires (backend, Supabase, déploiement, OAuth…)
                    à la racine — utiles si tu étends le projet au-delà de la version « lite » décrite dans le README principal.
                    Dépôt :
                    <a href="https://github.com/kruzeyy/football-manager-lite" target="_blank" rel="noopener noreferrer">kruzeyy/football-manager-lite</a>.
                </p>
            </div>
        </main>

        <footer class="site-footer">
            <div class="container footer-inner">
                <p class="footer-copy">
                    © {{ 'now'|date('Y') }} {{ site_name }}. Tous droits réservés.
                </p>
                <ul class="footer-social" aria-label="Réseaux sociaux">
                    <li>
                        <a href="{{ site_github }}" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><i class="fa-brands fa-github" aria-hidden="true"></i></a>
                    </li>
                    <li>
                        <a href="{{ site_linkedin }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
                    </li>
                </ul>
                {% include '_footer_mentions_compact.html.twig' %}
            </div>
        </footer>
    </div>
{% endblock %}
